# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./price_radar.db
# Active le scheduler de vérification automatique (true/false)
SCHEDULER_ENABLED=true
# Fréquence de vérification par défaut d'un produit (minutes)
DEFAULT_CHECK_FREQUENCY=360

# --- Scraping ---
# Délai minimal / maximal entre deux requêtes vers un même domaine (secondes)
SCRAPE_MIN_DELAY=2.0
SCRAPE_MAX_DELAY=5.0
SCRAPE_TIMEOUT=30
SCRAPE_RETRIES=3
# Respecter robots.txt (fortement recommandé)
RESPECT_ROBOTS_TXT=true
# Utiliser Playwright en fallback si requests échoue (nécessite playwright installé)
USE_PLAYWRIGHT_FALLBACK=false
# Furtivité TLS : imite l'empreinte JA3 d'un vrai navigateur (curl_cffi).
# Débloque les sites qui filtrent au niveau TLS. NE résout PAS les CAPTCHA.
USE_CURL_CFFI=true
CURL_CFFI_IMPERSONATE=chrome
# Proxy optionnel (http://user:pass@host:port) — laissé vide si non utilisé
SCRAPE_PROXY=

# --- Seuils d'alerte (modifiables aussi dans l'UI > Paramètres) ---
ALERT_MIN_GAP_PERCENT=40
ALERT_MIN_MARGIN_EUR=100
ALERT_ONLY_IN_STOCK=true

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=price-radar@example.com
ALERT_EMAIL_TO=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord ---
DISCORD_WEBHOOK_URL=

# --- Connecteurs d'API officielles ---
# Cache des réponses : Redis si renseigné, sinon cache mémoire
REDIS_URL=
# User-Agent envoyé aux API (mets un contact réel pour Nominatim/OFF)
API_USER_AGENT=price-radar/1.0 (veille tarifaire; contact@example.com)

# eBay Browse API — https://developer.ebay.com/ (application keyset)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_FR

# Amazon Product Advertising API v5 — compte Associates requis
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_HOST=webservices.amazon.fr
AMAZON_REGION=eu-west-1
AMAZON_MARKETPLACE=www.amazon.fr

# AliExpress Open Platform — https://open.aliexpress.com/
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=

# Google Merchant / Content API — compte marchand + service account JSON
GOOGLE_MERCHANT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# UPCitemDB — vide = palier trial gratuit (quota limité)
UPCITEMDB_KEY=

# Barcode Lookup — https://www.barcodelookup.com/api
BARCODE_LOOKUP_KEY=

# OpenStreetMap (sans clé)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OVERPASS_URL=https://overpass-api.de/api/interpreter

# --- Pool de proxies publics gratuits ---
# Active la rotation de proxies pour le scraping (sources : proxy_sources.json)
PROXY_POOL_ENABLED=false
# Rafraîchissement automatique des listes (minutes)
PROXY_REFRESH_MINUTES=30
# Timeout de téléchargement d'une source (secondes)
PROXY_FETCH_TIMEOUT=20
# URL utilisée pour tester si un proxy fonctionne
PROXY_TEST_URL=http://httpbin.org/ip
# Timeout d'un test de proxy (secondes)
PROXY_TEST_TIMEOUT=8
# Nombre de tests en parallèle
PROXY_TEST_WORKERS=50
# Nombre max de proxies testés par cycle (les listes en contiennent des milliers)
PROXY_TEST_LIMIT=400
# Suppression d'un proxy après N échecs consécutifs
PROXY_MAX_FAILS=3
